# Local .terraform directories
**/.terraform/*
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Terraform plan files
*.tfplan
*.plan

# Variable files containing secrets
*.tfvars
*.tfvars.json

# Exception: keep the example variables file
!terraform.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# Lock file (keep this if working in a team)
# Comment out the next line if you want to commit it
# .terraform.lock.hcl

# macOS
.DS_Store

# VS Code
.vscode/

# JetBrains IDEs
.idea/

# Vim
*.swp
*.swo